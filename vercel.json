{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "site",
  "cleanUrls": true,
  "functions": {
    "api/notion-publish.js": { "maxDuration": 60 },
    "api/regenerate-carousel.js": { "maxDuration": 60 },
    "api/poll-notion.js": { "maxDuration": 60 },
    "api/publish-social-post.js": { "maxDuration": 60 },
    "api/manage-schedules.js": { "maxDuration": 30 },
    "api/generate-image.js": { "maxDuration": 60 },
    "api/generate-campaign.js": { "maxDuration": 30 },
    "api/compile-carousel.js": { "maxDuration": 60 },
    "api/create-signature-request.js": { "maxDuration": 30 },
    "api/sign-document.js": { "maxDuration": 30 }
  },
  "crons": [
    { "path": "/api/poll-notion", "schedule": "0 8 * * *" }
  ],
  "headers": [
    {
      "source": "/api/og",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, s-maxage=3600" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Link", "value": "</llms.txt>; rel=\"describedby\"; type=\"text/markdown\", </.well-known/api-catalog>; rel=\"api-catalog\"; type=\"application/linkset+json\", </.well-known/agent-skills/index.json>; rel=\"agent-skills\"; type=\"application/json\", </auth.md>; rel=\"author\"; type=\"text/markdown\", </sitemap.xml>; rel=\"sitemap\"; type=\"application/xml\"" }
      ]
    },
    {
      "source": "/.well-known/api-catalog",
      "headers": [
        { "key": "Content-Type", "value": "application/linkset+json; charset=utf-8" }
      ]
    },
    {
      "source": "/(llms.txt|llms-full.txt|auth.md|.well-known/auth.md)",
      "headers": [
        { "key": "Content-Type", "value": "text/markdown; charset=utf-8" }
      ]
    }
  ]
}
